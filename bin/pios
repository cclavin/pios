#!/usr/bin/env bash
# bin/pios — PIOS Validation and Status CLI

set -euo pipefail

# Find project root
PIOS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

STATUS_FILE="$PIOS_ROOT/STATUS.md"
TASKS_FILE="$PIOS_ROOT/templates/tasks.md"
SPEC_FILE="$PIOS_ROOT/templates/spec-lock.md"

get_frontmatter_val() {
  local file="$1"
  local key="$2"
  awk -v k="$key" '
    BEGIN { in_fm=0 }
    /^---$/ { in_fm = !in_fm; next }
    in_fm && $0 ~ "^"k":" { 
      sub("^"k":[ \t]*", ""); 
      gsub(/^"|"$/, ""); 
      print; 
      exit 
    }
  ' "$file"
}

cmd_status() {
  if [ ! -f "$STATUS_FILE" ]; then
    echo "{\"error\": \"STATUS.md not found\"}"
    exit 1
  fi

  local current_gate
  current_gate=$(get_frontmatter_val "$STATUS_FILE" "current_gate")

  local pending=0
  local in_prog=0
  local done_c=0

  if [ -f "$TASKS_FILE" ]; then
    pending=$(grep -c "^### \[ \]" "$TASKS_FILE" || true)
    in_prog=$(grep -c "^### \[\/\]" "$TASKS_FILE" || true)
    done_c=$(grep -c "^### \[x\]" "$TASKS_FILE" || true)
  fi

  cat <<EOF
{
  "current_gate": "$current_gate",
  "tasks": {
    "pending": $pending,
    "in_progress": $in_prog,
    "completed": $done_c
  }
}
EOF
}

cmd_validate() {
  if [ ! -f "$STATUS_FILE" ]; then
    echo "Error: STATUS.md not found."
    exit 1
  fi

  local current_gate
  current_gate=$(get_frontmatter_val "$STATUS_FILE" "current_gate")

  # We use Plan Lock as the example since spec-lock.md contains the exit criteria for Plan Lock
  if [ "$current_gate" = "Plan Lock" ]; then
    echo "Validating exit criteria from spec-lock.md..."
    if [ ! -f "$SPEC_FILE" ]; then
      echo "Error: spec-lock.md not found."
      exit 1
    fi
    
    # Using awk to extract only criteria inside the 'Exit Criteria' section
    local unchecked
    unchecked=$(awk '
      /^## Exit Criteria/ { in_section=1; next }
      /^## / { if(in_section) in_section=0 }
      in_section && /^- \[ \]/ { missing++ }
      END { print missing + 0 }
    ' "$SPEC_FILE")
    
    if [ "$unchecked" -gt 0 ]; then
      echo "Validation Failed: Found $unchecked unchecked exit criteria in spec-lock.md."
      awk '
        /^## Exit Criteria/ { in_section=1; next }
        /^## / { if(in_section) in_section=0 }
        in_section && /^- \[ \]/ { print }
      ' "$SPEC_FILE"
      exit 1
    else
      echo "Validation Passed: All exit criteria met."
      exit 0
    fi
  else
    echo "Validation logic for gate '$current_gate' is not implemented in this minimal v0.2 scaffolding."
    exit 0
  fi
}

case "${1:-}" in
  status)
    cmd_status
    ;;
  validate)
    cmd_validate
    ;;
  *)
    echo "Usage: pios <status|validate>"
    exit 1
    ;;
esac
